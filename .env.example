# ===========================================
# FluenZ - Environment Configuration
# ===========================================
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_DB=fluenz_db
POSTGRES_USER=fluenz_user
POSTGRES_PASSWORD=fluenz_secret
POSTGRES_HOST_PORT=5432

# ---------- Backend (Spring Boot) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fluenz_db
SPRING_DATASOURCE_USERNAME=fluenz_user
SPRING_DATASOURCE_PASSWORD=fluenz_secret
BACKEND_PORT=8080

# ---------- Frontend (Vite) ----------
FRONTEND_PORT=5173
